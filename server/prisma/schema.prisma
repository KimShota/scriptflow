generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  scripts   Script[]
  analyses  Analysis[]
}

model Script {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  title            String
  mission          String?
  status           Status   @default(draft)

  // Hook
  hookTitle        String?
  hookVisual       String?
  hookVerbal       String?

  // Storytelling Framework
  storyProblem     String?
  storyPromise     String?
  storyCredibility String?
  storyDelivery    String?
  storyCta         String?

  // Production
  footageNeeded    String?
  audio            String?
  caption          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Status {
  draft
  ready
  posted
}

model Analysis {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])

  // Creator info
  creatorName  String
  reelLink     String?
  views        Int?

  // Hook
  hookTitle    String?
  hookVisual   String?
  hookVerbal   String?

  // Content structure
  storyArc     String?
  pacing       Pacing?
  cta          String?
  format       String?
  duration     String?

  // Audio
  audio        Audio?
  audioCustom  String?

  // Notes
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Pacing {
  fast
  medium
  slow
}

enum Audio {
  mix
  voiceover
  trending_sounds
  dialogue_bg_music
  dialogue_only
  no_voice
  custom
}